{
  "name": "box-open-elements",
  "version": "0.1.0",
  "private": true,
  "description": "Box Open Elements: an open, framework-agnostic design system and web component library for Box-style experiences",
  "license": "MIT",
  "packageManager": "bun@1.3.11",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./foundations/*": {
      "types": "./dist/foundations/*/index.d.ts",
      "import": "./dist/foundations/*/index.js"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js"
    },
    "./patterns/content-explorer": {
      "types": "./dist/patterns/content-explorer/index.d.ts",
      "import": "./dist/patterns/content-explorer/index.js"
    },
    "./patterns/content-explorer/selection": {
      "types": "./dist/patterns/content-explorer/selection/index.d.ts",
      "import": "./dist/patterns/content-explorer/selection/index.js"
    },
    "./patterns/content-explorer/collection": {
      "types": "./dist/patterns/content-explorer/collection/index.d.ts",
      "import": "./dist/patterns/content-explorer/collection/index.js"
    },
    "./patterns/content-explorer/navigation": {
      "types": "./dist/patterns/content-explorer/navigation/index.d.ts",
      "import": "./dist/patterns/content-explorer/navigation/index.js"
    },
    "./patterns/content-explorer/actions": {
      "types": "./dist/patterns/content-explorer/actions/index.d.ts",
      "import": "./dist/patterns/content-explorer/actions/index.js"
    },
    "./patterns/search": {
      "types": "./dist/patterns/search/index.d.ts",
      "import": "./dist/patterns/search/index.js"
    },
    "./patterns/item": {
      "types": "./dist/patterns/item/index.d.ts",
      "import": "./dist/patterns/item/index.js"
    },
    "./patterns/metadata": {
      "types": "./dist/patterns/metadata/index.d.ts",
      "import": "./dist/patterns/metadata/index.js"
    },
    "./patterns/share": {
      "types": "./dist/patterns/share/index.d.ts",
      "import": "./dist/patterns/share/index.js"
    },
    "./patterns/preview": {
      "types": "./dist/patterns/preview/index.d.ts",
      "import": "./dist/patterns/preview/index.js"
    },
    "./patterns/file-request": {
      "types": "./dist/patterns/file-request/index.d.ts",
      "import": "./dist/patterns/file-request/index.js"
    },
    "./patterns/task": {
      "types": "./dist/patterns/task/index.d.ts",
      "import": "./dist/patterns/task/index.js"
    },
    "./patterns/governance": {
      "types": "./dist/patterns/governance/index.d.ts",
      "import": "./dist/patterns/governance/index.js"
    },
    "./patterns/insights": {
      "types": "./dist/patterns/insights/index.d.ts",
      "import": "./dist/patterns/insights/index.js"
    },
    "./patterns/*": {
      "types": "./dist/patterns/*.d.ts",
      "import": "./dist/patterns/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p packages/box-server/tsconfig.json --noEmit && tsc -p storybook/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "verify": "bun run typecheck && bun run test && bun run build",
    "preview:capture": "bun run build && bun tools/preview/capture.ts",
    "docs": "bun run build && bun docs-site/server.ts",
    "docs:typecheck": "tsc -p docs-site/tsconfig.json",
    "docs:build": "bun run build && bun docs-site/build.ts",
    "site:build": "bun run build && bun run storybook:build && bun docs-site/build.ts",
    "docs:shots": "bun run build && bun tools/preview/docs-site-shots.ts",
    "test:regression": "bun run build && bun tools/preview/regression.ts",
    "test:regression:pixel": "bash tools/preview/container-run.sh 'bun run test:regression -- --pixel'",
    "baselines:regen": "bash tools/preview/container-run.sh 'bun run build && bun tools/preview/capture.ts && bun tools/preview/docs-site-shots.ts'",
    "storybook:extract": "bun storybook/extract.ts",
    "storybook:dev": "bun run build && bun storybook/server.ts",
    "storybook:build": "bun run build && bun storybook/build.ts"
  },
  "devDependencies": {
    "@types/pngjs": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.2",
    "bun-types": "^1.3.14",
    "jsdom": "^29.0.1",
    "pixelmatch": "^7.2.0",
    "playwright-core": "^1.61.1",
    "pngjs": "^7.0.0",
    "typescript": "^5.8.2",
    "vitest": "^4.1.2"
  }
}
