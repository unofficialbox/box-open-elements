{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["bun-types"],
    "paths": {
      "@unofficialbox/box-open-elements": ["../src/index.ts"],
      "@unofficialbox/box-open-elements/patterns/content-explorer": ["../src/patterns/content-explorer/index.ts"],
      "@unofficialbox/box-open-elements/patterns/search": ["../src/patterns/search/index.ts"]
    }
  },
  "include": ["./**/*.ts"]
}
